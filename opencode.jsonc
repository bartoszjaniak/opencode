{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "elrond",
  "agent": {
    "elrond": {
      "description": "Główny orchestrator — zwołuje Radę, generuje draft, ocenia uwagi subagentów i finalizuje specyfikację",
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "prompt": "{file:./prompts/elrond.md}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "question": "allow",
        "webfetch": "allow"
      }
    }
  }
}